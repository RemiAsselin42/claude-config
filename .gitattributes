* text=auto eol=lf
*.sh text eol=lf

# If a fork versions vault/ (graphify reports + canvas), keep the local freshly
# regenerated copy on merge conflicts so multi-machine syncs never produce
# conflict markers. Requires `git config merge.ours.driver true` (install.sh sets
# it). Harmless when vault/ is gitignored (the default for this public template).
vault/** merge=ours
# Generated artifacts (graphify writes CRLF on Windows): disable eol conversion
# entirely. `text eol=lf` is not enough — git keeps warning "CRLF will be
# replaced by LF" on every `git diff` as long as the working copy is CRLF.
# Store the bytes as produced; the merge drivers below absorb cross-machine noise.
vault/** -text
graphify-out/** -text

# Union-merge for the knowledge graph. Requires graphify's merge driver
# (`graphify hook install` sets merge.graphify.driver). Clones without it fall
# back to the default merge; harmless when graphify-out/ is gitignored (the
# default for this public template).
graphify-out/graph.json merge=graphify

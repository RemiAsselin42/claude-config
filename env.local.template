# Copy this file to env.local and fill in the values for this machine
# env.local is gitignored — never commit this file


# Figma API Key for the official Figma Claude MCP plugin. Get it from 
# https://www.figma.com/developers/api#access-tokens (optional)
#
# export FIGMA_API_KEY="figd_"


# MemPalace — embedding model (optional)
# Picks how memories are vectorized. install.sh writes the chosen value into
# ~/.mempalace/config.json; it is deliberately NOT exported, because the env var
# outranks that file and a stale one in a shell profile would silently override
# every later run. Two values only — anything else silently falls back to minilm:
#
#                   Default here. Multilingual (100+ languages), ~300 MB, ONNX
#  embeddinggemma   on CPU. Pick this if you write in a language other than
#                   English. Slow to index on a modest CPU.
#
#                   MemPalace's own default. all-MiniLM-L6-v2, English-only
#  minilm           training, ~30 MB, much faster. Fine if you always query in
#                   English (which CLAUDE.md asks for anyway).
#
# Switching on an existing palace invalidates every vector: install.sh detects
# the mismatch and asks before re-indexing. Uncomment to override the default.
#
# MEMPALACE_EMBEDDING_MODEL="minilm"
#
# Where the palace lives. Only set this if ~/.mempalace/palace is unsuitable
# (small system drive, synced folder — chromadb does not tolerate sync tools).
#
# MEMPALACE_PALACE_PATH="/d/mempalace/palace"


# Graphify — community naming (optional)
# `graphify update` is AST-only and leaves communities as "Community 12", which
# is what ends up in GRAPH_REPORT, in the canvas groups and in every vault note.
# install.sh runs one LLM pass per repo to name them, only when names are missing
# or still placeholders. Default backend is the `claude` CLI already on PATH — no
# API key involved. Values: claude-cli | gemini | openai | deepseek | kimi |
# ollama | none. Anything but claude-cli and ollama needs the matching API key
# exported below (GEMINI_API_KEY, OPENAI_API_KEY, ...).
#
# GRAPHIFY_LABEL_BACKEND="ollama"
# GEMINI_API_KEY="sk-..."   
#
# Model override for that backend. Leave unset to take the backend's default;
# with claude-cli that means whatever model the CLI is configured with.
#
# GRAPHIFY_LABEL_MODEL="llama3"
#
# Deep semantic re-extraction (optional, off by default)
# The AST pass only links what it resolves locally, which leaves config files,
# entry points and standalone scripts as isolated islands in the graph. Deep mode
# re-reads the code with the LLM and adds the INFERRED edges that connect them.
# Costs a full pass over every indexed repo — slow, and billed if the backend is
# a paid API. Turn it on when the graph feels too fragmented to navigate.

GRAPHIFY_DEEP_EXTRACT="false"


# Zilliz semantic vector search (optional — for large repos only)
# When set, Claude uses semantic search before grep for "find where X is handled" queries.
# Requires: Zilliz Cloud account (cloud.zilliz.com) + OpenAI API key (for embeddings)
# After setting these, run install.sh to install the MCP server + register it.
#
# export MILVUS_ADDRESS="https://xxx.api.gcp-us-west1.zillizcloud.com"
# export MILVUS_TOKEN="your-zilliz-api-key"
# export OPENAI_API_KEY="sk-..."   # used for embedding model
